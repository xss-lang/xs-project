{
  "C_Cpp.errorSquiggles": "disabled",

  "files.associations": {
    "CmakeLists.txt": "cmake",
    "CMakeCache.txt": "cmake",
    "*.xs": "xs",
    "*.ll": "llvm",
    "*.asm": "asm-intel-x86-generic"
  },
  "files.watcherExclude": {
    "**/build/**": true,
    "**/target/**": true,
    "**/node_modules/**": true,
    "**/out/**": true,
    "**/dist/**": true
  },
  "search.exclude": {
    "**/build": true,
    "**/target": true,
    "**/node_modules": true,
    "**/out": true,
    "**/dist": true
  },
  "rust-analyzer.files.excludeDirs": ["build", "node_modules", "out", "dist"],
  "rust-analyzer.linkedProjects": [
    "xslang/Cargo.toml",
    "xsfmt/Cargo.toml",
    "xstidy/Cargo.toml",
    "xs-analyzer/Cargo.toml"
  ],
  "FSharp.suggestGitignore": false,
  "r.lsp.promptToInstall": false,
  "java.configuration.updateBuildConfiguration": "automatic",
  "C_Cpp.codeAnalysis.clangTidy.checks.disabled": ["clang-diagnostic-error"]
}
