{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch XS Analyzer Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/xs-analyzer"
      ],
      "outFiles": [
        "${workspaceFolder}/xs-analyzer/dist/**/*.js"
      ]
    }
  ]
}
