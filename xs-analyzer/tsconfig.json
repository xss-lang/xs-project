{
  "compilerOptions": {
    "alwaysStrict": true,
    "composite": false,
    "declaration": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["ES2025"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmitOnError": true,
    "outDir": "dist",
    "rootDir": "sources",
    "strict": true,
    "target": "ES2025"
  },
  "include": ["sources/extension/**/*.ts"]
}
