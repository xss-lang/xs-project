{
  "name": "xs-analyzer",
  "displayName": "XS Analyzer",
  "description": "Future VS Code extension for the X# Rust language server.",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:xs"
  ],
  "main": "./dist/extension/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "xs",
        "aliases": [
          "X#",
          "XS"
        ],
        "extensions": [
          ".xs"
        ]
      }
    ],
    "configuration": {
      "title": "XS Analyzer",
      "properties": {
        "xs-analyzer.lens.enable": {
          "type": "boolean",
          "default": false
        },
        "xs-analyzer.lens.run.enable": {
          "type": "boolean",
          "default": false
        },
        "xs-analyzer.lens.debug.enable": {
          "type": "boolean",
          "default": false
        },
        "xs-analyzer.hover.actions.enable": {
          "type": "boolean",
          "default": false
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "format": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/json": "^2.0.0",
    "@types/node": "^26.0.1",
    "@types/vscode": "^1.100.0",
    "eslint": "^10.6.0",
    "prettier": "^3.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0"
  }
}
