// VS Code settings.json defaults for X#.
// Inlay hints are not configured here.

{
  "[xs]": {
    "editor.defaultFormatter": "xs-lang.xs-analyzer"
  },

  // xs-analyzer: baseline LSP behavior.
  "xs-analyzer.checkOnSave": true, // defaults to true if omitted

  // CodeLens / hover.
  "xs-analyzer.lens.enable": true, // defaults to false if omitted
  "xs-analyzer.lens.run.enable": true, // defaults to false if omitted
  "xs-analyzer.lens.debug.enable": true, // defaults to false if omitted
  "xs-analyzer.hover.actions.enable": true, // defaults to false if omitted

  // Avoid watching and indexing noisy directories in large projects.
  "files.watcherExclude": {
    "**/target/**": true,
    "**/.git/**": true
  },
  "search.exclude": {
    "**/target": true
  },
  "files.exclude": {
    "**/target": true
  },

  // Useful when XS Analyzer Debug CodeLens is enabled.
  "debug.allowBreakpointsEverywhere": true // defaults to false if omitted
}
