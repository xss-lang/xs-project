fn add_byte(left: Byte, right: Byte) -> Byte {
  return left + right;
}

fn div_sbyte(left: SByte, right: SByte) -> SByte {
  return left / right;
}

fn add_ushort(left: UShort, right: UShort) -> UShort {
  return left + right;
}

fn add_short(left: Short, right: Short) -> Short {
  return left + right;
}

fn add_ulong(left: ULong, right: ULong) -> ULong {
  return left + right;
}

fn div_uint(left: UInt, right: UInt) -> UInt {
  return left / right;
}

fn less_uinteger(left: UInteger, right: UInteger) -> Bool {
  return left < right;
}

fn shift_uinteger(left: UInteger, right: UInteger) -> UInteger {
  return left >> right;
}

fn less_integer(left: Integer, right: Integer) -> Bool {
  return left < right;
}

fn shift_integer(left: Integer, right: Integer) -> Integer {
  return left >> right;
}

fn main() -> Long {
  return 0;
}
