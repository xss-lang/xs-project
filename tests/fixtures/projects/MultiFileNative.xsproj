appName: "MultiFileNative"
appVersion: "0.1.6"
appRelease: "BETA"
appLicense: "Apache-2.0"

appAuthors {
    ["Leitwolf", "xs-lang.chess031@slmails.com"]
}

compilerOptions {
    xsVersion: "26"

    addFiles {
        entry: "source/MultiFileMain.xs"
        ["source/MultiFileHelper.xs"]
    }

    output {
        [osName: "Linux"; osArch: "x64"]
    }
}
