fn byte_max() -> Byte {
  return 255;
}

fn sbyte_min() -> SByte {
  return -128;
}

fn short_min() -> Short {
  return -32'768;
}

fn ushort_max() -> UShort {
  return 65'535;
}

fn ulong_max() -> ULong {
  return 4'294'967'295;
}

fn uint_max() -> UInt {
  return 18'446'744'073'709'551'615;
}

fn integer_min() -> Integer {
  return -170'141'183'460'469'231'731'687'303'715'884'105'728;
}

fn uinteger_max() -> UInteger {
  return 340'282'366'920'938'463'463'374'607'431'768'211'455;
}

fn main() -> Long {
  return 0;
}
