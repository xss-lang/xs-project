appName: "NativeMain"
appVersion: "0.0.1"
appRelease: "BETA"
appLicense: "Apache-2.0"

appAuthors {
    ["Leitwolf", "xs-lang.chess031@slmails.com"]
}

compilerOptions {
    xsVersion: "26"
    xsBackend: "LLVM"

    addFiles {
        entry: "source/NativeMain.xs"
    }

    output {
        [
            osName: "Linux"
            osArch: "x64"
        ]
    }
}
