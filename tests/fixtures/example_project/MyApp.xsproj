appName: "MyApp"
appVersion: "0.0.1"
appRelease: "BETA"
appLicense: "MIT"

appAuthors {
    ["Alpha", "alfa@example.me"]
    ["Foo", "foo@baz.me"]
}

compilerOptions {
    xsVersion: "26"

    addFiles {
        entry: "source/Main.xs"

        [
            "source/Foo.xs",
            "source/Bar.xs"
        ]
    }

    output {
        [
            osName: "Linux"
            osArch: "x64"
        ]
    }
}

externalModules {
    addModule {
        moduleName: "xsmods.Foo"
        moduleRepo: "https://github.com/xss-lang/externalModules"
        moduleVersion: "0.1"
    }
}

