appName: "MacroApp"
appVersion: "0.0.1"
appRelease: "ALPHA"
appLicense: None

appAuthors {
    [None, None]
}

compilerOptions {
    xsVersion: "26"
    xsBackend: "LLVM"

    addFiles {
        entry: "source/Main.xs"
    }

    output {
        [
            osName: "Linux"
            osArch: "x64"
        ]
    }
}
